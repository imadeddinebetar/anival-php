{
  "name": "imadeddinebetar/anival-php",
  "description": "Anival PHP framework skeleton application.",
  "authors": [
    {
      "name": "Imad Eddine Betar",
      "email": "contac@imadeddinebetar.com"
    }
  ],
  "license": "MIT",
  "version": "1.0.0",
  "type": "project",
  "require": {
    "php": "^8.3",
    "ext-redis": "*",
    "psr/http-message": "^2.0",
    "psr/http-server-handler": "^1.0",
    "psr/http-server-middleware": "^1.0",
    "psr/container": "^2.0",
    "nyholm/psr7": "^1.8",
    "nyholm/psr7-server": "^1.0",
    "nikic/fast-route": "^1.3",
    "php-di/php-di": "^7.0",
    "illuminate/database": "^11.0",
    "illuminate/view": "^11.0",
    "illuminate/events": "^11.0",
    "respect/validation": "^2.3",
    "symfony/security-csrf": "^7.0",
    "symfony/cache": "^7.0",
    "symfony/http-foundation": "^7.0",
    "vlucas/phpdotenv": "^5.6",
    "monolog/monolog": "^3.5",
    "workerman/workerman": "^5.0",
    "illuminate/hashing": "^11.47",
    "illuminate/pagination": "^11.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^1.10",
    "squizlabs/php_codesniffer": "^3.8",
    "symfony/var-dumper": "^7.0"
  },
  "autoload": {
    "psr-4": {
          "App\\": "app/",
          "Core\\": "core/",
          "Bootstrap\\": "bootstrap/",
          "Database\\Factories\\": "database/factories/",
          "Database\\Seeders\\": "database/seeders/"
      },
    "files": [
      "core/Support/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse",
    "format": "phpcbf"
  }
}
